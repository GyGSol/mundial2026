PORT=5000
MONGODB_URI=mongodb://127.0.0.1:27017/mundial2026
JWT_SECRET=change-me-in-production
CLIENT_ORIGIN=http://localhost:5173
WORLD_CUP_API_URL=https://worldcup26.ir
WORLD_CUP_SYNC_EMAIL=
WORLD_CUP_SYNC_PASSWORD=
SYNC_INTERVAL_MS=60000
SYNC_INTERVAL_LIVE_MS=15000
KICKOFF_WATCH_MS=15000
SIMULATION_ENABLED=true
# Sesiones de jugadores: 2 horas (fijo en sessionService.js)

# Admin (opcional en local; en Heroku se crea en el primer ingreso en /admin/setup)
# ADMIN_USERNAME=admin
# ADMIN_PASSWORD=change-me-admin-password
ADMIN_JWT_EXPIRES=8h

# Football-Data.org (opcional: squads en vivo, lineups e historial)
FOOTBALL_DATA_API_TOKEN=
FOOTBALL_DATA_API_URL=https://api.football-data.org/v4

# FIFA (eventos oficiales: timeline + PDF opcional)
FIFA_API_URL=https://api.fifa.com/api/v3
FIFA_COMPETITION_ID=17
FIFA_SEASON_ID=285023
FIFA_REPORT_ASSET_PREFIX=ce281
FIFA_REPORT_ID_BASE=12451

# Predicciones IA (Cerebras + fallback Gemini/Groq) — usuario bot ~90 min antes del kickoff
AI_PREDICTIONS_ENABLED=true
AI_USER_EMAIL=predictivemodeling@gmail.com
CEREBRAS_API_KEY=
GOOGLE_AI_API_KEY=
GROQ_API_KEY=
AI_DEFAULT_PROVIDER=cerebras
# Opcional: mercado y xG para el competidor IA (Predictive Modeling)
ODDS_API_KEY=
ODDS_API_SPORT=soccer_fifa_world_cup
API_FOOTBALL_KEY=
API_FOOTBALL_URL=https://v3.football.api-sports.io
API_FOOTBALL_SEASON=2026
AI_PREDICT_LEAD_MS=5400000
AI_PREDICT_WINDOW_MS=600000
AI_PREDICT_JOB_INTERVAL_MS=300000
AI_CEREBRAS_MODEL=gpt-oss-120b
AI_GEMINI_MODEL=gemini-2.5-flash
AI_GROQ_MODEL=llama-3.3-70b-versatile

# Oracle Predictive Modeling (Cerebras structured outputs + training buffer)
ORACLE_STRUCTURED_OUTPUT=true
ORACLE_LIVE_ADJUSTMENT_MS=30000
ORACLE_INTERNAL_SECRET=
OPENFOOTBALL_CACHE_DIR=training/data/openfootball
TRAINING_BUFFER_EXPORT_CRON=0 3 * * 0
TRAINING_BUFFER_ALWAYS_RECORD=false

# Frontend (Vite) — Google Cast / Chromecast en transmisión en vivo
# VITE_CAST_APP_ID=CC1AD845
