{
  "name": "mundial2026-predicciones",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "backend",
    "frontend"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev -w backend\" \"npm run dev -w frontend\"",
    "build": "npm run build -w frontend && node scripts/copy-frontend.js",
    "test": "npm run test -w backend",
    "sync": "npm run sync -w backend",
    "sync:streams": "npm run sync:streams -w backend",
    "sync:players": "npm run sync:players -w backend",
    "sync:history": "node scripts/sync-wikipedia-history.mjs",
    "sync:wiki-nations": "node scripts/sync-wikipedia-nation-records.mjs",
    "build:players-seed": "npm run build:players-seed -w backend",
    "simulate": "npm run simulate -w backend",
    "reset-db": "npm run reset-db -w backend",
    "prepare-package": "node scripts/prepare-package.js",
    "package-zip": "node scripts/prepare-package.js",
    "oracle:export": "npm run oracle:export -w backend",
    "oracle:preprocess": "python3 training/preprocess_oracle_data.py",
    "start": "node backend/src/index.js",
    "heroku-postbuild": "npm install --include=dev && npm run build"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  },
  "engines": {
    "node": "24.x"
  }
}
