# Perfil QA local — copia de prod en MongoDB local (mundial2026_local).
# Copiar a .env.local-qa (gitignored) y usar: npm run dev:local-qa
#
# cp .env.local-qa.example .env.local-qa

MONGODB_URI=mongodb://127.0.0.1:27017/mundial2026_local
APP_ENV=local-qa
CLIENT_ORIGIN=http://localhost:5173

# No escribir en prod ni molestar usuarios reales
BACKUP_ENABLED=false
PUSH_NOTIFICATIONS_ENABLED=false
AI_PREDICTIONS_ENABLED=false

# SMTP vacío — no emails a jugadores
SMTP_HOST=
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Token para npm run db:clone-from-prod (solo lectura del repo de backups)
# BACKUP_GITHUB_TOKEN=
# BACKUP_GITHUB_REPO=GyGSol/mundial2026-db-backups

# Opcional: copiar JWT_SECRET de prod para reutilizar sesiones entre URLs
# JWT_SECRET=
